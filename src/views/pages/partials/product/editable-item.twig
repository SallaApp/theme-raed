{% set mode = mode|default('cart') %}
{% set show_delete_button = show_delete_button is defined ? show_delete_button : mode == 'cart' %}
{% set show_item_offers = show_item_offers is defined ? show_item_offers : mode == 'cart' %}
{% set load_eager = load_eager|default(false) %}
{% set item_total = item.detailed_offers|length > 0 ? item.total_special_price|money : item.total|money %}
{% set has_order_extras = mode == 'order' and (item.availability_date or item.booking_location or item.product_reservations is not empty or item.notes or item.attachments|length) %}

<section class="cart-item bg-white p-5 xs:p-7 rounded-md mb-5 relative">
    <div class="md:flex rtl:space-x-reverse md:space-x-12 items-start justify-between mb-8 last:mb-0">
        <div class="flex flex-1 rtl:space-x-reverse space-x-4">
            <a href="{{ item.url }}" class="relative overflow-hidden shrink-0">
                <img src="{{ item.product_image }}"
                     alt="{{ item.product_name }}"
                     loading="{{ load_eager ? 'eager' : 'lazy' }}"
                     class="flex-none w-24 h-20 border border-gray-200 bg-gray-100 rounded-md object-center object-cover">

                <div class="free-ribbon absolute top-[11px] right-[-38px] w-32 bg-red-600 text-white text-xs font-bold text-center py-1 rotate-45 shadow-md {{ (item.price.getMoney().amount == 0 and item.has_discount) ? '' : 'hidden' }}">
                    {{ trans('pages.loyalty_program.free_product') }}
                </div>
            </a>

            <div class="space-y-1">
                <h2 class="text-gray-900 leading-6 text-lg">
                    <a href="{{ item.url }}" class="text-base">{{ item.product_name }}</a>
                </h2>

                <span class="text-sm text-gray-500 line-through item-regular-price {{ item.offer ? '' : 'hidden' }}">{{ item.product_price|money }}</span>
                <span class="inline-flex gap-1 leading-4 text-sm text-gray-500 line-through item-original-price {{ item.is_on_sale ? '' : 'hidden' }}" id="original_price">{{ item.original_price|money }}</span>
                <span class="inline-flex gap-1 leading-4 item-price {{ item.has_discount ? 'text-red-800' : 'text-sm text-gray-500' }}" id="has_discount">{{ item.price|money }}</span>

                {% if item.weight_label %}
                    <p class="text-sm text-gray-500">
                        {{ trans('pages.products.weight') }}
                        <span>{{ item.weight_label }}</span>
                    </p>
                {% endif %}

                {% if show_item_offers %}
                    <span class="old-offers flex items-center gap-1 mx-1.5 {{ item.detailed_offers ? 'hidden' : '' }}">
                        <i class="sicon-discount-calculator text-gray-500 offer-icon {{ item.offer ? '' : 'hidden' }}"></i>
                        <span class="text-sm text-gray-500 offer-name {{ item.offer ? '' : 'hidden' }}">{{ item.offer.names }}</span>
                    </span>

                    <salla-cart-item-offers
                        quantity="{{ item.quantity }}"
                        item-id="{{ item.id }}"
                        product-price="{{ item.product_price }}"
                        offers="{{ item.detailed_offers|json_encode }}"></salla-cart-item-offers>
                {% endif %}
            </div>
        </div>

        <div class="border-t border-b border-gray-200 py-3 md:p-0 md:border-none mt-5 md:mt-0 flex gap-8 justify-between items-center md:items-start">
            {% if item.type == 'donating' %}
                <span></span>
            {% elseif item.is_hidden_quantity %}
                <input type="hidden" value="{{ item.quantity }}" name="quantity" aria-label="Quantity"/>
                <span class="w-10 text-center">{{ item.quantity }}</span>
            {% else %}
                <salla-quantity-input
                    {% if mode == 'cart' %}cart-item-id="{{ item.id }}"{% endif %}
                    {% if item.max_quantity %}max="{{ item.max_quantity }}"{% endif %}
                    class="transtion transition-color duration-300"
                    aria-label="Quantity"
                    value="{{ item.quantity }}"
                    name="quantity">
                </salla-quantity-input>
            {% endif %}

            <p class="text-primary flex-none font-bold text-sm rtl:md:pl-12 ltr:md:pr-12">
                <span>{{ trans('pages.cart.total') }}:</span>
                <span class="inline-block item-total">{{ item.is_available ? item_total : trans('pages.cart.out_of_stock') }}</span>
            </p>
        </div>
    </div>

    {% include 'pages.partials.product.options' with { product: item } %}

    {% if has_order_extras %}
        <div class="mt-5 pt-5 border-t border-gray-100 space-y-4">
            {% if item.availability_date %}
                <div class="flex gap-2 text-sm text-blue-500">
                    <i class="sicon-info"></i>
                    <span>
                        {{ trans('pages.products.expected_to_be') }}:
                        <b>{{ item.availability_date|date('Y-m-d') }}</b>
                    </span>
                </div>
            {% endif %}

            {% if item.booking_location %}
                <ul class="font-medium text-xs text-gray-600">
                    <li class="flex justify-between items-baseline">
                        <span class="text-sm font-bold">{{ trans('common.elements.location') }}</span>
                        <span class="text-unicode">{{ item.booking_location }}</span>
                    </li>
                </ul>
            {% endif %}

            {% if item.product_reservations is not empty %}
                <div>
                    <h3 class="mb-3.5 text-sm font-bold">
                        {{ item.product_reservations.count() > 1 ? trans('pages.cart.reservations') : trans('pages.cart.item_options') }}
                    </h3>
                    <div class="rounded-md p-4 border border-gray-200">
                        {% include 'pages.partials.product.reservations' with { reservations: item.product_reservations } %}
                    </div>
                </div>
            {% endif %}

            {% if item.notes %}
                <div class="text-sm text-gray-500">
                    <span class="font-medium text-gray-700">{{ trans('common.elements.note') }}:</span>
                    <span>{{ item.notes }}</span>
                </div>
            {% endif %}

            {% if item.attachments|length %}
                <div class="flow-root rounded-md px-4 border border-gray-200">
                    <dl class="text-sm text-dark divide-y divide-border-color">
                        {% for attachment in item.attachments %}
                            <div class="py-3.5 md:flex items-center justify-between">
                                <dt class="mb-2 md:mb-0">
                                    {{ trans('pages.products.attachments') }}
                                </dt>
                                <dd class="font-medium {{ attachment.type == 'image' ? 'text-gray-900' : 'text-xs' }}">
                                    <a href="{{ attachment.url }}" target="_blank">
                                        {% if attachment.type == 'image' %}
                                            <div class="flex rtl:space-x-reverse space-x-2.5">
                                                <img class="h-7 w-7 object-cover rounded-md"
                                                     src="{{ attachment.url }}"
                                                     alt="{{ item.product_name }}"/>
                                            </div>
                                        {% else %}
                                            {{ trans('pages.orders.file_url') }}
                                        {% endif %}
                                    </a>
                                </dd>
                            </div>
                        {% endfor %}
                    </dl>
                </div>
            {% endif %}
        </div>
    {% endif %}

    {% if show_delete_button %}
        <span class="absolute top-1.5 rtl:left-1.5 ltr:right-1.5 rtl:xs:left-5 ltr:xs:right-5 xs:top-5">
            <salla-button type="button" shape="icon" size="small" color="danger" class="btn--delete" aria-label="Remove from the cart"
                          onclick="salla.cart.deleteItem('{{ item.id }}').then(() => document.querySelector('#item-{{ item.id }}').remove())">
                <i class="sicon-cancel"></i>
            </salla-button>
        </span>
    {% endif %}
</section>
