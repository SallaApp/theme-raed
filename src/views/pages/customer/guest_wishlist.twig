{#
| Variable   | Type                 | Description |
|------------|----------------------|-------------|
| page       | object               |             |
| page.title | string               |             |
#}
{% extends "layouts.master" %}

{% block head_scripts %}
	<script defer data-cfasync="false" src="{{ 'guest-wishlist.js'|asset }}"></script>
{% endblock %}

{% block content %}
<div class="container py-8 md:py-12">
	<h1 class="text-xl font-bold mb-6">{{ page.title }}</h1>

	{# Empty state — shown when no items in localStorage #}
	<div id="guest-wishlist-empty" class="hidden text-center py-16 px-4">
		<i class="sicon-heart text-6xl text-gray-300 mb-6 block"></i>
		<h2 class="text-lg font-bold text-gray-700 mb-2">
			{{ 'pages.wishlist.guest_empty_title'|trans }}
		</h2>
		<p class="text-gray-500 mb-6 max-w-md mx-auto">
			{{ 'pages.wishlist.guest_empty_message'|trans }}
		</p>
		<salla-button onclick="salla.event.dispatch('login::open')" color="primary">
			{{ 'pages.wishlist.register_cta'|trans }}
		</salla-button>
	</div>

	{# Product list — populated by JS from localStorage product IDs #}
	<div id="guest-wishlist-items" class="space-y-5 hidden">
		{# Items rendered dynamically by guest-wishlist.js #}
	</div>

	{# Loading state #}
	<div id="guest-wishlist-loading" class="text-center py-16">
		<div class="s-loader"></div>
	</div>
</div>
{% endblock %}
